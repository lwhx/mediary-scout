<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Electron's V8 needs JIT + writable/executable memory under hardened runtime. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!--
      REQUIRED so the ELECTRON_RUN_AS_NODE child can load better-sqlite3's
      native .node, which is signed by our identity (or unsigned) rather than
      by Apple. Without this, hardened runtime blocks the dylib load and the
      SQLite-backed server child crashes on start.
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
